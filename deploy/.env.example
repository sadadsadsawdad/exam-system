# 部署配置示例文件
# 复制此文件为 .env 并修改相应配置

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=exam
DB_USER=examuser
DB_PASSWORD=your_strong_password_here

# 服务器配置
SERVER_IP=your_server_ip
SERVER_DOMAIN=your-domain.com

# 后端配置
BACKEND_PORT=8081
BACKEND_DEPLOY_DIR=/opt/exam-backend

# 前端配置
FRONTEND_DEPLOY_DIR=/var/www/exam-frontend

# 备份配置
BACKUP_DIR=/opt/backups
BACKUP_RETENTION_DAYS=7

# GCC 编译器路径
GCC_PATH=gcc
