<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springboot.dao.MessageMapper">

    <resultMap id="MessageResultMap" type="com.example.springboot.entity.Message">
        <id property="id" column="id"/>
        <result property="scope" column="scope"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="sender" column="sender"/>
        <result property="senderId" column="sender_id"/>
        <result property="createTime" column="create_time"/>
        <result property="status" column="status"/>
        <result property="classId" column="class_id"/>
        <result property="type" column="type"/>
        <result property="relatedId" column="related_id"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.springboot.entity.Message" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO message (scope, title, content, sender, sender_id, create_time, status, class_id, type, related_id)
        VALUES (#{scope}, #{title}, #{content}, #{sender}, #{senderId}, #{createTime}, #{status}, #{classId}, #{type}, #{relatedId})
    </insert>

    <select id="selectAll" resultMap="MessageResultMap">
        SELECT * FROM message ORDER BY create_time DESC
    </select>

    <select id="selectByCondition" resultMap="MessageResultMap">
        SELECT * FROM message
        <where>
            <if test="scope != null and scope != ''">
                AND scope = #{scope}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="sender != null and sender != ''">
                AND sender LIKE CONCAT('%', #{sender}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="selectById" resultMap="MessageResultMap">
        SELECT * FROM message WHERE id = #{id}
    </select>

    <update id="update" parameterType="com.example.springboot.entity.Message">
        UPDATE message
        <set>
            <if test="scope != null">scope = #{scope},</if>
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="sender != null">sender = #{sender},</if>
            <if test="senderId != null">sender_id = #{senderId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="classId != null">class_id = #{classId},</if>
            <if test="type != null">type = #{type},</if>
            <if test="relatedId != null">related_id = #{relatedId},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM message WHERE id = #{id}
    </delete>

    <update id="updateStatus">
        UPDATE message SET status = #{status} WHERE id = #{id}
    </update>

</mapper>
