<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springboot.dao.UserMapper">
    <resultMap id="BaseResultMap" type="com.example.springboot.entity.User">
        <id property="id" column="id"/>
        <result property="username" column="Username"/>
        <result property="password" column="Pwd"/>
        <result property="role" column="role"/>
        <result property="classId" column="class_id"/>
        <result property="avatar" column="avatar"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="lastLoginTime" column="last_login_time"/>
        <result property="lastLoginIp" column="last_login_ip"/>
    </resultMap>

    <!-- 带班级名称的结果映射 -->
    <resultMap id="UserWithClassMap" type="com.example.springboot.entity.User">
        <id property="id" column="id"/>
        <result property="username" column="Username"/>
        <result property="password" column="Pwd"/>
        <result property="role" column="role"/>
        <result property="classId" column="class_id"/>
        <result property="className" column="className"/>
        <result property="avatar" column="avatar"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="lastLoginTime" column="last_login_time"/>
        <result property="lastLoginIp" column="last_login_ip"/>
    </resultMap>

    <!-- 根据ID查询用户 -->
    <select id="selectById" resultMap="UserWithClassMap">
        SELECT u.*, c.name as className 
        FROM userlist u 
        LEFT JOIN clazz c ON u.class_id = c.id 
        WHERE u.id = #{id}
    </select>

    <!-- 查询所有用户（带班级名称） -->
    <select id="selectAll" resultMap="UserWithClassMap">
        SELECT u.*, c.name as className 
        FROM userlist u 
        LEFT JOIN clazz c ON u.class_id = c.id 
        ORDER BY u.id DESC
    </select>

    <!-- 根据用户名查询用户 -->
    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT * FROM userlist WHERE Username = #{username}
    </select>

    <!-- 根据邮箱查询用户（数据库无此列，返回null） -->
    <select id="selectByEmail" resultMap="BaseResultMap">
        SELECT * FROM userlist WHERE 1=0
    </select>

    <!-- 根据手机号查询用户（数据库无此列，返回null） -->
    <select id="selectByPhone" resultMap="BaseResultMap">
        SELECT * FROM userlist WHERE 1=0
    </select>

    <!-- 搜索用户（支持用户名模糊查询、角色和状态过滤，带班级名称） -->
    <select id="searchUsers" resultMap="UserWithClassMap">
        SELECT u.*, c.name as className 
        FROM userlist u 
        LEFT JOIN clazz c ON u.class_id = c.id
        <where>
            <if test="username != null and username != ''">
                AND u.Username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="role != null and role != ''">
                AND u.role = #{role}
            </if>
            <if test="status != null">
                AND u.status = #{status}
            </if>
        </where>
        ORDER BY u.id DESC
    </select>

    <!-- 插入用户 -->
    <insert id="insert" parameterType="com.example.springboot.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO userlist (Username, Pwd, role, class_id, avatar, status, create_time) 
        VALUES (#{username}, #{password}, #{role}, #{classId}, #{avatar}, 
                COALESCE(#{status}, 1), COALESCE(#{createTime}, NOW()))
    </insert>

    <!-- 更新用户信息 -->
    <update id="update" parameterType="com.example.springboot.entity.User">
        UPDATE userlist
        <set>
            <if test="username != null">Username = #{username},</if>
            <if test="password != null">Pwd = #{password},</if>
            <if test="role != null">role = #{role},</if>
            <if test="classId != null">class_id = #{classId},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 更新密码 -->
    <update id="updatePassword">
        UPDATE userlist SET Pwd = #{password} WHERE id = #{id}
    </update>

    <!-- 更新用户状态 -->
    <update id="updateStatus">
        UPDATE userlist SET status = #{status} WHERE id = #{id}
    </update>

    <!-- 批量更新用户状态 -->
    <update id="batchUpdateStatus">
        UPDATE userlist SET status = #{status} WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <!-- 更新最后登录信息 -->
    <update id="updateLoginInfo">
        UPDATE userlist SET last_login_time = #{lastLoginTime}, last_login_ip = #{lastLoginIp} WHERE id = #{id}
    </update>

    <!-- 删除用户 -->
    <delete id="delete" parameterType="int">
        DELETE FROM userlist WHERE id = #{id}
    </delete>

    <!-- 批量删除用户 -->
    <delete id="batchDelete">
        DELETE FROM userlist WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 统计用户总数 -->
    <select id="count" resultType="int">
        SELECT COUNT(*) FROM userlist
    </select>

    <!-- 根据角色统计用户数量 -->
    <select id="countByRole" resultType="int">
        SELECT COUNT(*) FROM userlist WHERE role = #{role}
    </select>

    <!-- 根据状态统计用户数量 -->
    <select id="countByStatus" resultType="int">
        SELECT COUNT(*) FROM userlist WHERE status = #{status}
    </select>

    <!-- 根据班级ID查询用户 -->
    <select id="selectByClassId" resultMap="UserWithClassMap">
        SELECT u.*, c.name as className 
        FROM userlist u 
        LEFT JOIN clazz c ON u.class_id = c.id 
        WHERE u.class_id = #{classId}
        ORDER BY u.id
    </select>

    <!-- 更新用户的班级ID -->
    <update id="updateClazzId">
        UPDATE userlist SET class_id = #{clazzId} WHERE id = #{userId}
    </update>
</mapper>